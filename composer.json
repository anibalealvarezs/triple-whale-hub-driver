{
    "name": "anibalealvarezs/triple-whale-hub-driver",
    "description": "Triple Whale driver for the Hub ecosystem",
    "license": "MIT",
    "authors": [
        {
            "name": "Aníbal Álvarez",
            "email": "anibalealvarezs@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "anibalealvarezs/api-client-skeleton": "dev-main",
        "anibalealvarezs/api-driver-core": "dev-main",
        "anibalealvarezs/triple-whale-api": "dev-main",
        "psr/log": "^1.0 || ^2.0 || ^3.0",
        "symfony/http-foundation": "^6.0 || ^7.0"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://satis.anibalalvarez.com/"
        }
    ],
    "autoload": {
        "psr-4": {
            "Anibalealvarezs\\TripleWhaleHubDriver\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": false,
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "doctrine/instantiator": "^1.5",
        "phpunit/phpunit": "^9.6.20"
    }
}
